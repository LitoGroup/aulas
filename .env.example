# Copie para .env.local e preencha com valores reais. NUNCA commite .env.local
# Conexao Prisma/Postgres (Supabase)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?sslmode=require"

# Auth.js
NEXTAUTH_SECRET="gerar-com: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Supabase
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Seed (usuario admin inicial)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="troque-isto"
